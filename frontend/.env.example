# Sanity CMS (required for /admin and content)
# Get these from https://www.sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Public site URL (used for SEO canonical, OpenGraph, robots, sitemap)
# Examples:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://yourname.vercel.app
# NEXT_PUBLIC_SITE_URL=https://yourdomain.tld
NEXT_PUBLIC_SITE_URL=https://yourdomain.tld

# Optional: override API version for GROQ
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
